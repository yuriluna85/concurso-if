						<style type="text/css">
/* Sanfoninhas Gerais */
#sanfoninhas details:not(:checked) summary:before,
#sanfoninhas details summary:before,
#sanfoninhas details details:not(:checked) summary:after,
#sanfoninhas details details summary:after{
	content: " ▾ ";
}

#sanfoninhas details:checked summary:before,
#sanfoninhas details[open] summary:before,
#sanfoninhas details details:checked summary:after,
#sanfoninhas details details[open] summary:after{
	content: " ▴ ";
}

#sanfoninhas details{
    background: #dff0d8;
    border: 1px solid #ccc;
    margin:5px auto;
    padding: 10px;
}

#sanfoninhas details summary{
   font-weight: 700;
}

#sanfoninhas details[open] summary, #sanfoninhas details:checked summary{
   margin-bottom:20px;
}



/*Este comando oculta o título "Índice de Artigos" de todas as páginas com abas do site*/
.article-index h3{display:none;}



/*Banner topo home*/
.banner-topo-home img{
margin-bottom: 10px;
}

/*Boxes coloridos*/

.boxes{
  width: 250px;
  float: left;
  position: relative;
    margin: 5%;
  text-align: center;
border-radius: 5px;
min-width: 200px;
}

.boxes a{
	text-decoration: none;
    color: white;
  	padding: 30px;
    display:block;


}

/*CLAUBER*/
/*.row-fluid{
   margin-bottom:20px;
}*/
/*fim de CLAUBER*/


.boxes-red{background-image: linear-gradient(to top, rgba(200,0,10,10), rgba(255,0,0,1));}
.boxes-green{background-image: linear-gradient(to bottom, rgba(0,255,50,1), rgba(0,100,90,1));}

/*IFRAMES DE INFOGRAFIA*/
.iframe_info{
   border:0px solid;
   border-radius:20px;
   max-height:90vmin;
   max-width:90vmin;
   height:750px;
   width:750px;
}


/*Estilos para o balanço trabalho remoto 2020*/
	.balanco{
               display: block;
		margin: 50px 50px 400px 50px;
	}
	.menu-balanco li{
		font-family: 'Oswald', san-serif;
		list-style: none;
		font-size: 22px;
		display: inline-block;
	}
	.menu-balanco li a{
                font-size: 22px;
		color: #fff;
		float: left;
		padding: 30px;
		background: rgb(0,128,128);
		border-bottom: 4px #9F1A4C solid;
		margin-left: 10px;
		margin-bottom: 10px;
		width: 200px;
		text-align: center;
		text-decoration: none;
	}
	.menu-balanco li a:hover{
		background: #9F1A4C;
		font-size: 22px;
	}
		
	.proreitoria h2{
		font-family: 'Oswald', san-serif;
		font-size: 2.2em!important;
		font-weight: 400!important;
		color: rgb(0,128,128);
		display: table;
		width: 100%;
		border-bottom: 1px #9F1A4C solid;
		margin-bottom: 1em;
	}
	.proreitoria h3{
		font-family: 'Oswald', san-serif;
		font-size: 1.8em;
		font-weight: 400;
		color: rgb(0,128,128);
		margin-bottom: 1em;
		margin-top: 0px!important;
	}
	.box-cinza{
		border: 2px solid rgb(211,211,211);
		border-radius: 10px;
		padding: 30px;
		background: rgb(220,220,220, 0.2);
		width: 90%;
		margin-bottom: 30px;
	}
	.box-cinza li{
		list-style: none;
		line-height: 1.5em;
		margin-bottom: 1em;
		margin-left: 0px;
		
	}
	.box-cinza ul li::before {
  		content: "\25AA";
		color: rgb(0,128,128);
		font-weight: bold;
		display: inline-block; 
		width: 30px;
		margin-left: -30px;
	}
	.box-cinza ul ul li::before {
  		content: "\002D";
		color: #9F1A4C;
		font-weight: bold;
		display: inline-block; 
		width: 30px;
		margin-left: -30px;
	}


/*****ESTILOS PARA A IV JORNADA DE INTEGRAÇÃO EM 2020*****/

@font-face {
  font-family: Poppins;
  src: url('https://ifes.edu.br/images/font/poppins.ttf');
}

.img_ivjornada{border-radius:25px;}

.menu_ivjornada{
   display: table;
   font-weight: 600;
   margin-bottom: 40px;
   padding: 0px;
   text-align: center;
   width: 100%;
}
.a_ivjornada, .a_ivjornada:hover, .a_ivjornada:active, .a_ivjornada:visited{
   align-items: center;
   background-color: #d80077;
   margin: 10px 10px 0px 0px;
   color: #fff;
   display:flex;
   flex-flow: row wrap;
   justify-content: center;
   float: left;
   font-family: 'Poppins', sans-serif;
   font-size: 24px;
   max-height: 50px;
   min-height: 50px;
   overflow: hidden;
   padding: 5px;
   max-width: 355px;
   min-width: 355px;
}

.titulo_ivjornada{ 
   color: #117a45 !important;
   font-family: 'Poppins', sans-serif;
   font-weight: bold;
   margin-top: 60px !important;
   width: 100%;
}

h3.titulo_ivjornada{
   font-size: 20pt;
}


/*BLOCO DE ESTILOS DA PÁGINA DO CORONAVÍRUS*/


@font-face {
  font-family: Oswald;
  src: url('https://ifes.edu.br/images/font/oswald.ttf');
}


@font-face {
  font-family: Open Sans;
  src: url('https://ifes.edu.br/images/font/open-sans.ttf');
}


.img-titulo-cv{
border-radius: 30px 30px 0 0;
}

.h3-cv, .h4-cv, .h5-cv{
   color: #117a45 !important;
   font-family: 'Oswald', sans-serif;
   font-weight: 400 !important;
   margin-top: 60px !important;
   width: 100%;
}

.h3-cv{
   border-bottom: 1px solid #9F1A4C;
   font-size: 36px !important;
   margin-top: 60px !important;
}

.h4-cv{
   font-size: 24px !important;
   margin-top: 30px !important;
}

.h5-cv{
   font-size: 18px !important;
   margin-top: 30px !important;
}

.menu-cv{
   border: 0px solid #ccc;
   float:left;
   font-weight: 600;
   margin-bottom: 40px;
   padding: 0px;
   text-align: center;
}
.a-cv, .a-cv:hover, .a-cv:active, .a-cv:visited{
   align-items: center;
   background: url("https://ifes.edu.br/images/2020/coronavirus/fundo-bt.png");
   margin: 10px 10px 0px 0px;
   color: #fff;
   display:flex;
   flex-flow: row wrap;
   justify-content: center;
   float: left;
   font-family: 'Oswald', sans-serif;
   font-size: 24px;
   max-height: 50px;
   min-height: 50px;
   overflow: hidden;
   padding: 5px;
   max-width: 355px;
   min-width: 355px;
}

.a-cv span{
   display:block !important;
   /*float:none;*/
   margin: 0px;
   padding;0px;
   width: 100%;
}

.a-cv span.sub{
   border: 0px solid #ccc;
   font-size: 14px;
   font-family: "Open Sans";
   font-weight: 200;
   /*line-height: 14px;*/
   /*bottom: 40px;*/
}

.table-cv, .table-cv th, .table-cv td{
   border: 1px solid #fff;
}

.table-cv tr:nth-child(even) {background: rgba(17,122,69,0.2)}
.table-cv tr:nth-child(odd) {background: rgba(17,122,69,0.1)}

.table-cv{
