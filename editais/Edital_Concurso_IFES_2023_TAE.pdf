/*BOTÃO INSCREVA-SE*/
.button-inscreva-se {
  display: inline-block;
  border-radius: 12px;
  background-color: #4CAF50;
  border: none;
  color: #FFFFFF;
  text-align: center;
 text-color: #FFFFFF;
  font-size: 20px;
  padding: 16px 30px 16px 30px;
  /*width: 200px;*/
  transition: all 0.5s;
  cursor: pointer;
  margin: 5px;
}
.button-inscreva-se a:link .button-inscreva-se a:visited .button-inscreva-se a:active .button-inscreva-se a:hover .button-inscreva-se a:focus {
 color: #FFFFFF;
}
.button-inscreva-se a:focus {
 color: #FFFFFF;
}
.button-inscreva-se a:hover {
 color: #FFFFFF;
}
.button-inscreva-se span {
  cursor: pointer;
  display: inline-block;
  position: relative;
  transition: 0.5s;
 text-color: #FFFFFF;
 color: #FFFFFF;

}

.button-inscreva-se span:after {
  content: '\00bb';
  position: absolute;
  opacity: 0;
  top: 0;
  right: -20px;
  transition: 0.5s;
  color: #FFFFFF;
}

.button-inscreva-se:hover span {
  padding-right: 25px;
  color: #FFFFFF;
}

.button-inscreva-se:hover span:after {
  opacity: 1;
  right: 0;
  color: #FFFFFF;
}
/*--------Accordion verde-------*/
.acc-kontainer {
  width: 100%;
  margin: auto;
  color:#000;
}
.acc-kontainer .acc-body {
  width: 98%;
  width: calc(100% - 20px);
  margin: 0 auto;
  height: 0;
  color: rgba(0, 0, 0, 0);
  background-color: rgba(76, 175, 80, 0.2);
  line-height: 28px;
  padding: 0 15px;
  box-sizing: border-box;
  transition: 0.5s;
  overflow: hidden;
}

.acc-kontainer label {
  cursor: pointer;
  background-color: rgba(76, 175, 80, 0.7);
  border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  display: block;
  padding: 10px;
  width: 100%;
  color: #fff;
  font-weight: 400;
  box-sizing: border-box;
  z-index: 100;
}

.acc-kontainer input{
  display: none;
}

.acc-kontainer label:before {
  font-family: 'FontAwesome';
  content: '\f067';
  font-weight: bolder;
  float: right;
}

.acc-kontainer input:checked+label {
  background-color: rgba(76, 175, 80, 1);
}

.acc-kontainer input:checked+label:before {
  font-family: 'FontAwesome';
  content: '\f00d';
  transition: 0.5s;
}

.acc-kontainer input:checked~.acc-body {
  height: auto;
  color: #000;
  font-size: 16px;
  padding: 20px;
  transition: 0.5s;
}

/*--------variação de cores da accordion para cidade da inovacao-------*/
.acc-kontainer-cdi {
  width: 100%;
  margin: auto;
  color:#000;
}
.acc-kontainer-cdi .acc-body {
  width: 98%;
  width: calc(100% - 20px);
  margin: 0 auto;
  height: 0;
  color: rgba(0, 0, 0, 0);
  background-color: rgba(141, 166, 132, 0.2);
  line-height: 28px;
  padding: 0 15px;
  box-sizing: border-box;
  transition: 0.5s;
  overflow: hidden;
}

.acc-kontainer-cdi label {
  cursor: pointer;
  background-color: rgba(141, 166, 132, 1);
  border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  display: block;
  padding: 10px;
  width: 100%;
  color: #fff;
  font-weight: 400;
  box-sizing: border-box;
  z-index: 100;
}

.acc-kontainer-cdi input{
  display: none;
}

.acc-kontainer-cdi label:before {
  font-family: 'FontAwesome';
  content: '\f067';
  font-weight: bolder;
  float: right;
}

.acc-kontainer-cdi input:checked+label {
  background-color: rgba(3, 99, 85, 1); 
}

.acc-kontainer-cdi input:checked+label:before {
  font-family: 'FontAwesome';
  content: '\f00d';
  transition: 0.5s;
}

.acc-kontainer-cdi input:checked~.acc-body {
  height: auto;
  color: #000;
  font-size: 16px;
  padding: 20px;
  transition: 0.5s;
}

/*--------box de atenção amarelo-------*/
.atencao {
  margin-bottom: 15px;
  padding: 4px 12px;
  background-color: #ffffcc;
  border-left: 6px solid #ffeb3b;
}
